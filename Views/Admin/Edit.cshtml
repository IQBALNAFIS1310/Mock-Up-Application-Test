@model bodata_calon_karyawan.Models.ViewModels.BiodataFormVM

@{
    ViewData["Title"] = "Edit Biodata";
    Layout = null;
}

<!DOCTYPE html>

<html>

<head>

    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1">

    <title>Edit Biodata</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet" />

    <link href="~/css/form.css"
          rel="stylesheet" />

</head>

<body>

    <div class="container mt-4 mb-5">

        <form asp-action="Edit"
              method="post">

            <input asp-for="Biodata.Id" type="hidden" />

            <input asp-for="Biodata.UserId" type="hidden" />

            <partial name="~/Views/Form/Partial/_Petunjuk.cshtml" model="Model" />

            <partial name="~/Views/Form/Partial/_DataPribadi.cshtml" model="Model" />

            <partial name="~/Views/Form/Partial/_Pendidikan.cshtml" model="Model" />

            <partial name="~/Views/Form/Partial/_Pelatihan.cshtml" model="Model" />

            <partial name="~/Views/Form/Partial/_Pekerjaan.cshtml" model="Model" />

            <partial name="~/Views/Form/Partial/_Skill.cshtml" model="Model" />

            <partial name="~/Views/Form/Partial/_Konfirmasi.cshtml" model="Model" />

        </form>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/js/form.js"></script>

</body>

</html>