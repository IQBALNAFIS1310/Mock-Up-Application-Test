@model bodata_calon_karyawan.Models.ViewModels.BiodataFormVM

@{
    ViewData["Title"] = "Detail Pelamar";
    Layout = null;
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<div class="container mt-4">

    <div class="d-flex justify-content-between mb-4">

        <h2>Detail Biodata Pelamar</h2>

        <a asp-action="Index" class="btn btn-secondary">
            Kembali
        </a>

    </div>

    <div class="card shadow">

        <div class="card-header bg-primary text-white">

            Data Pribadi

        </div>

        <div class="card-body">

            <table class="table table-borderless">

                <tr>
                    <th width="250">Posisi Dilamar</th>
                    <td>@Model.Biodata.PosisiDilamar</td>
                </tr>

                <tr>
                    <th>Nama</th>
                    <td>@Model.Biodata.Nama</td>
                </tr>

                <tr>
                    <th>No KTP</th>
                    <td>@Model.Biodata.NoKtp</td>
                </tr>

                <tr>
                    <th>Tempat Lahir</th>
                    <td>@Model.Biodata.TempatLahir</td>
                </tr>

                <tr>
                    <th>Tanggal Lahir</th>
                    <td>@Model.Biodata.TanggalLahir?.ToString("dd MMMM yyyy")</td>
                </tr>

                <tr>
                    <th>Jenis Kelamin</th>
                    <td>@Model.Biodata.JenisKelamin</td>
                </tr>

                <tr>
                    <th>Agama</th>
                    <td>@Model.Biodata.Agama</td>
                </tr>

                <tr>
                    <th>Golongan Darah</th>
                    <td>@Model.Biodata.GolonganDarah</td>
                </tr>

                <tr>
                    <th>Status</th>
                    <td>@Model.Biodata.Status</td>
                </tr>

                <tr>
                    <th>Alamat KTP</th>
                    <td>@Model.Biodata.AlamatKtp</td>
                </tr>

                <tr>
                    <th>Alamat Tinggal</th>
                    <td>@Model.Biodata.AlamatTinggal</td>
                </tr>

                <tr>
                    <th>Email</th>
                    <td>@Model.Biodata.Email</td>
                </tr>

                <tr>
                    <th>No Telepon</th>
                    <td>@Model.Biodata.NoTelp</td>
                </tr>

                <tr>
                    <th>Kontak Darurat</th>
                    <td>@Model.Biodata.KontakDarurat</td>
                </tr>

                <tr>
                    <th>Skill</th>
                    <td>@Model.Biodata.Skill</td>
                </tr>

                <tr>
                    <th>Bersedia Ditempatkan</th>
                    <td>
                        @(Model.Biodata.BersediaDitempatkan ? "Ya" : "Tidak")
                    </td>
                </tr>

                <tr>
                    <th>Gaji Diharapkan</th>
                    <td>
                        Rp @Model.Biodata.GajiDiharapkan?.ToString("N0")
                    </td>
                </tr>

            </table>

        </div>

    </div>

    <br />

    <div class="card shadow">

        <div class="card-header bg-success text-white">

            Pendidikan

        </div>

        <div class="card-body">

            <table class="table table-bordered">

                <thead>

                    <tr>

                        <th>Jenjang</th>

                        <th>Institusi</th>

                        <th>Jurusan</th>

                        <th>Tahun</th>

                        <th>IPK</th>

                    </tr>

                </thead>

                <tbody>

                    @foreach (var item in Model.PendidikanList)
                    {
                        <tr>

                            <td>@item.Jenjang</td>

                            <td>@item.NamaInstitusi</td>

                            <td>@item.Jurusan</td>

                            <td>@item.TahunLulus</td>

                            <td>@item.Ipk</td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

    <br />

    <div class="card shadow">

        <div class="card-header bg-warning">

            Pelatihan

        </div>

        <div class="card-body">

            <table class="table table-bordered">

                <thead>

                    <tr>

                        <th>Nama Kursus</th>

                        <th>Sertifikat</th>

                        <th>Tahun</th>

                    </tr>

                </thead>

                <tbody>

                    @foreach (var item in Model.PelatihanList)
                    {
                        <tr>

                            <td>@item.NamaKursus</td>

                            <td>@(item.Sertifikat ? "Ada" : "Tidak")</td>

                            <td>@item.Tahun</td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

    <br />

    <div class="card shadow">

        <div class="card-header bg-info text-white">

            Riwayat Pekerjaan

        </div>

        <div class="card-body">

            <table class="table table-bordered">

                <thead>

                    <tr>

                        <th>Perusahaan</th>

                        <th>Posisi</th>

                        <th>Pendapatan</th>

                        <th>Tahun</th>

                    </tr>

                </thead>

                <tbody>

                    @foreach (var item in Model.PekerjaanList)
                    {
                        <tr>

                            <td>@item.NamaPerusahaan</td>

                            <td>@item.PosisiTerakhir</td>

                            <td>@item.PendapatanTerakhir</td>

                            <td>@item.Tahun</td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

    <div class="mt-4 text-end">

        <a asp-action="Edit"
           asp-route-id="@Model.Biodata.Id"
           class="btn btn-warning">

            Edit Data

        </a>

    </div>

</div>