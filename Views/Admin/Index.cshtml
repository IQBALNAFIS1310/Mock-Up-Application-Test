@model List<bodata_calon_karyawan.Models.ViewModels.BiodataFormVM>

@{
    ViewData["Title"] = "Admin";
    Layout = null;
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h2>Dashboard Admin</h2>
            <small class="text-muted">
                Data Biodata Calon Karyawan
            </small>
        </div>

        <a asp-controller="Auth"
           asp-action="Logout"
           class="btn btn-danger">
            Logout
        </a>

    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            @TempData["Success"]
        </div>
    }

    <div class="card shadow">

        <div class="card-header">

            <div class="row">

                <div class="col-md-4">

                    <input type="text"
                           id="searchNama"
                           class="form-control"
                           placeholder="Cari Nama">

                </div>

                <div class="col-md-4">

                    <input type="text"
                           id="searchPosisi"
                           class="form-control"
                           placeholder="Cari Posisi">

                </div>

                <div class="col-md-4">

                    <input type="text"
                           id="searchPendidikan"
                           class="form-control"
                           placeholder="Cari Pendidikan">

                </div>

            </div>

        </div>

        <div class="card-body">

            <table class="table table-bordered table-hover text-center align-middle">

                <thead class="table-dark">

                    <tr>

                        <th>Nama</th>

                        <th>Tempat & Tanggal Lahir</th>

                        <th>Posisi Dilamar</th>

                        <th>Pendidikan Terakhir</th>

                        <th width="250">
                            Aksi
                        </th>

                    </tr>

                </thead>

                <tbody id="tableBody">

                    @foreach (var item in Model)
                    {
                        var pendidikan = item.PendidikanList
                        .OrderByDescending(x => x.TahunLulus)
                        .FirstOrDefault();

                        <tr>

                            <td class="nama">
                                @item.Biodata.Nama
                            </td>

                            <td>

                                @item.Biodata.TempatLahir

                                <br />

                                @item.Biodata.TanggalLahir?.ToString("dd MMM yyyy")

                            </td>

                            <td class="posisi">
                                @item.Biodata.PosisiDilamar
                            </td>

                            <td class="pendidikan">

                                @(pendidikan == null
                                                            ? "-"
                                                            : pendidikan.Jenjang)

                        </td>

                            <td>

                                <a asp-action="Detail"
                                   asp-route-id="@item.Biodata.Id"
                                   class="btn btn-info btn-sm">

                                    Detail

                                </a>

                                <a asp-action="Edit"
                                   asp-route-id="@item.Biodata.Id"
                                   class="btn btn-warning btn-sm">

                                    Edit

                                </a>

                                <form asp-action="Delete"
                                      asp-route-id="@item.Biodata.Id"
                                      method="post"
                                      class="d-inline">

                                    @Html.AntiForgeryToken()

                                    <button type="submit"
                                            class="btn btn-danger btn-sm btnDelete">

                                        Delete

                                    </button>

                                </form>

                            </td>

                        </tr>
                                        }

                </tbody>

            </table>

        </div>

    </div>

</div>

<script>

    const nama=document.getElementById("searchNama");
    const posisi=document.getElementById("searchPosisi");
    const pendidikan=document.getElementById("searchPendidikan");

    function filterTable(){

        let n=nama.value.toLowerCase();
        let p=posisi.value.toLowerCase();
        let pd=pendidikan.value.toLowerCase();

        document.querySelectorAll("#tableBody tr").forEach(row=>{

            let nama=row.querySelector(".nama").innerText.toLowerCase();

            let posisi=row.querySelector(".posisi").innerText.toLowerCase();

            let pendidikan=row.querySelector(".pendidikan").innerText.toLowerCase();

            row.style.display=
            nama.includes(n)&&
            posisi.includes(p)&&
            pendidikan.includes(pd)
            ? ""
            : "none";

        });

    }

    nama.addEventListener("keyup",filterTable);
    posisi.addEventListener("keyup",filterTable);
    pendidikan.addEventListener("keyup",filterTable);

    document.querySelectorAll(".btnDelete").forEach(btn=>{

        btn.addEventListener("click",function(e){

            if(!confirm("Yakin ingin menghapus data?"))
            {
                e.preventDefault();
            }

        });

    });

</script>