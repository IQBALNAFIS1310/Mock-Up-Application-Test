@model bodata_calon_karyawan.Models.ViewModels.BiodataFormVM

<div class="card shadow-sm border-0 mb-4">

    <div class="card-header bg-secondary text-white">

        <h5 class="mb-0">
            ⭐ Informasi Tambahan
        </h5>

    </div>

    <div class="card-body">

        <div class="mb-4">

            <label asp-for="Biodata.Skill"
                   class="form-label fw-bold">

                Skill / Keahlian

            </label>

            <textarea asp-for="Biodata.Skill"
                      rows="5"
                      class="form-control"
                      placeholder="Contoh :
- C#
- ASP.NET Core
- SQL Server
- React
- Problem Solving"></textarea>

        </div>

        <div class="row">

            <div class="col-md-6">

                <label class="form-label fw-bold">

                    Bersedia Ditempatkan
                    di Seluruh Indonesia?

                </label>

                <div class="mt-2">

                    <div class="form-check">

                        <input asp-for="Biodata.BersediaDitempatkan"
                               value="true"
                               class="form-check-input"
                               type="radio">

                        <label class="form-check-label">

                            Ya

                        </label>

                    </div>

                    <div class="form-check">

                        <input asp-for="Biodata.BersediaDitempatkan"
                               value="false"
                               class="form-check-input"
                               type="radio">

                        <label class="form-check-label">

                            Tidak

                        </label>

                    </div>

                </div>

            </div>

            <div class="col-md-6">

                <label asp-for="Biodata.GajiDiharapkan"
                       class="form-label fw-bold">

                    Gaji Yang Diharapkan

                </label>

                <div class="input-group">

                    <span class="input-group-text">

                        Rp

                    </span>

                    <input asp-for="Biodata.GajiDiharapkan"
                           type="number"
                           class="form-control"
                           placeholder="5000000">

                </div>

            </div>

        </div>

    </div>

</div>