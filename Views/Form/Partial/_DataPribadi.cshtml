@model bodata_calon_karyawan.Models.ViewModels.BiodataFormVM

<div class="card shadow-sm border-0 mb-4">

    <div class="card-header bg-secondary text-white">

        <h5 class="mb-0">
            👤 Data Pribadi Pelamar
        </h5>

    </div>

    <div class="card-body">

        <div class="row">

            <div class="col-md-6 mb-3">

                <label asp-for="Biodata.PosisiDilamar" class="form-label fw-bold">
                    Posisi Yang Dilamar
                </label>

                <input asp-for="Biodata.PosisiDilamar"
                       class="form-control"
                       placeholder="Contoh : Programmer" />

            </div>

            <div class="col-md-6 mb-3">

                <label asp-for="Biodata.Nama" class="form-label fw-bold">
                    Nama Lengkap
                </label>

                <input asp-for="Biodata.Nama"
                       class="form-control" />

            </div>

            <div class="col-md-6 mb-3">

                <label asp-for="Biodata.NoKtp" class="form-label fw-bold">
                    Nomor KTP
                </label>

                <input asp-for="Biodata.NoKtp"
                       class="form-control" />

            </div>

            <div class="col-md-6 mb-3">

                <label asp-for="Biodata.Email" class="form-label fw-bold">
                    Email
                </label>

                <input asp-for="Biodata.Email"
                       type="email"
                       class="form-control" />

            </div>

            <div class="col-md-6 mb-3">

                <label asp-for="Biodata.TempatLahir" class="form-label fw-bold">
                    Tempat Lahir
                </label>

                <input asp-for="Biodata.TempatLahir"
                       class="form-control" />

            </div>

            <div class="col-md-6 mb-3">

                <label asp-for="Biodata.TanggalLahir" class="form-label fw-bold">
                    Tanggal Lahir
                </label>

                <input asp-for="Biodata.TanggalLahir"
                       type="date"
                       class="form-control" />

            </div>

            <div class="col-md-6 mb-3">

                <label class="form-label fw-bold">
                    Jenis Kelamin
                </label>

                <div>

                    <div class="form-check form-check-inline">

                        <input asp-for="Biodata.JenisKelamin"
                               class="form-check-input"
                               type="radio"
                               value="Laki-Laki">

                        <label class="form-check-label">
                            Laki-Laki
                        </label>

                    </div>

                    <div class="form-check form-check-inline">

                        <input asp-for="Biodata.JenisKelamin"
                               class="form-check-input"
                               type="radio"
                               value="Perempuan">

                        <label class="form-check-label">
                            Perempuan
                        </label>

                    </div>

                </div>

            </div>

            <div class="col-md-6 mb-3">

                <label asp-for="Biodata.Agama"
                       class="form-label fw-bold">
                    Agama
                </label>

                <input asp-for="Biodata.Agama"
                       class="form-control" />

            </div>

            <div class="col-md-6 mb-3">

                <label asp-for="Biodata.GolonganDarah"
                       class="form-label fw-bold">
                    Golongan Darah
                </label>

                <select asp-for="Biodata.GolonganDarah"
                        class="form-select">

                    <option value="">-- Pilih --</option>

                    <option>A</option>

                    <option>B</option>

                    <option>AB</option>

                    <option>O</option>

                </select>

            </div>

            <div class="col-md-6 mb-3">

                <label asp-for="Biodata.Status"
                       class="form-label fw-bold">
                    Status
                </label>

                <select asp-for="Biodata.Status"
                        class="form-select">

                    <option value="">-- Pilih --</option>

                    <option>Belum Menikah</option>

                    <option>Menikah</option>

                    <option>Cerai</option>

                </select>

            </div>

            <div class="col-md-6 mb-3">

                <label asp-for="Biodata.NoTelp"
                       class="form-label fw-bold">
                    Nomor Telepon
                </label>

                <input asp-for="Biodata.NoTelp"
                       class="form-control" />

            </div>

            <div class="col-12 mb-3">

                <label asp-for="Biodata.AlamatKtp"
                       class="form-label fw-bold">
                    Alamat KTP
                </label>

                <textarea asp-for="Biodata.AlamatKtp"
                          class="form-control"
                          rows="3"></textarea>

            </div>

            <div class="col-12 mb-3">

                <label asp-for="Biodata.AlamatTinggal"
                       class="form-label fw-bold">
                    Alamat Tinggal
                </label>

                <textarea asp-for="Biodata.AlamatTinggal"
                          class="form-control"
                          rows="3"></textarea>

            </div>

            <div class="col-md-12">

                <label asp-for="Biodata.KontakDarurat"
                       class="form-label fw-bold">
                    Orang Terdekat Yang Dapat Dihubungi
                </label>

                <input asp-for="Biodata.KontakDarurat"
                       class="form-control" />

            </div>

        </div>

    </div>

</div>