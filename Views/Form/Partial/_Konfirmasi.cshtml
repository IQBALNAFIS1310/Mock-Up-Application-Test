@model bodata_calon_karyawan.Models.ViewModels.BiodataFormVM

<div class="card shadow-sm border-0">

    <div class="card-header bg-success text-white">

        <h5 class="mb-0">
            ✅ Konfirmasi Pengiriman Biodata
        </h5>

    </div>

    <div class="card-body">

        <div class="alert alert-warning">

            <strong>Perhatian!</strong>

            <ul class="mt-3 mb-0">

                <li>Pastikan seluruh data yang Anda masukkan sudah benar.</li>

                <li>Setelah biodata dikirim, data tidak dapat diubah kembali oleh pelamar.</li>

                <li>Apabila terdapat kesalahan data, silakan hubungi Admin HRD.</li>

            </ul>

        </div>

        <div class="form-check mt-4">

            <input class="form-check-input"
                   type="checkbox"
                   id="checkSetuju">

            <label class="form-check-label"
                   for="checkSetuju">

                Saya menyatakan seluruh data yang saya isi adalah benar dan dapat dipertanggungjawabkan.

            </label>

        </div>

        <hr />

        <div class="d-flex justify-content-end">

            <button type="button"
                    class="btn btn-success btn-lg"
                    id="btnSimpan"
                    disabled
                    data-bs-toggle="modal"
                    data-bs-target="#modalKonfirmasi">

                Kirim Biodata

            </button>

        </div>

    </div>

</div>



<div class="modal fade"
     id="modalKonfirmasi"
     tabindex="-1">

    <div class="modal-dialog modal-dialog-centered">

        <div class="modal-content">

            @if (ViewBag.IsEdit == true)
            {
                <button class="btn btn-warning">
                    Update Biodata
                </button>
            }
            else
            {
                <button class="btn btn-success">
                    Simpan Biodata
                </button>
            }

            <div class="modal-body">

                <p class="mb-3">

                    Apakah Anda yakin ingin mengirim biodata?

                </p>

                <div class="alert alert-danger mb-0">

                    Setelah dikirim, biodata tidak dapat diedit kembali.

                </div>

            </div>

            <div class="modal-footer">

                <button class="btn btn-secondary"
                        data-bs-dismiss="modal">

                    Batal

                </button>

                <button type="submit"
                        class="btn btn-success">

                    Ya, Kirim Biodata

                </button>

            </div>

        </div>

    </div>

</div>